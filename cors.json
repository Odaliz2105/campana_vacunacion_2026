[
  {
    "origin": ["http://localhost:*", "https://localhost:*", "http://127.0.0.1:*"],
    "method": ["GET", "HEAD", "PUT", "POST", "DELETE", "OPTIONS"],
    "responseHeader": [
      "Content-Type",
      "Authorization",
      "Content-Length",
      "X-Requested-With",
      "x-firebase-storage-version"
    ],
    "maxAgeSeconds": 3600
  }
